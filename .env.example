COMPROMISED_KEY=0x_private_key_of_hacked_wallet
THROWAWAY_KEY=0x_private_key_of_fresh_throwaway_wallet
NEW_WALLET=0x_your_safe_destination_address
ENS_LABEL=yourname
FUND_AMOUNT=0.006

# ── Verifiable receipt (optional) ──
# JOB_ID salts the artifact_hash so identical rescues stay distinct. Auto-generated if unset.
JOB_ID=
# Agent signer (x-only hex pubkey) for the kind-30078 commit. Without it, only the artifact_hash is computed.
AGENT_PUBKEY=
# invinoveritas ledger READ base (mirrors: /ledger/{entry}/commitment + /outcome). Defaults to api.babyblueviper.com.
LEDGER_URL=https://api.babyblueviper.com
